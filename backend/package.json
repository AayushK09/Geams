    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.2.0",
    "@nestjs/websockets": "^10.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "mediasoup": "^3.13.17",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
